# FreshKeep backend — example environment file.
# Copy to `.env` (which is git-ignored) and fill in real values.
# Every setting is OPTIONAL: with no keys set, the backend runs fully offline
# using the deterministic MockVisionProvider.

# --- Vision provider selection -------------------------------------------
# One of: auto (default), mock, gemini, claude.
# "auto" picks a real provider only if a matching key is present (Claude wins,
# then Gemini), otherwise falls back to mock.
FRIDGE_VISION_PROVIDER=auto

# --- Google Gemini (real vision) -----------------------------------------
# Get a key at https://aistudio.google.com/apikey
# Either GOOGLE_API_KEY or GEMINI_API_KEY is accepted.
GOOGLE_API_KEY=
# GEMINI_API_KEY=
# FRIDGE_GEMINI_MODEL=gemini-2.5-flash-lite

# --- Anthropic Claude (alternative real vision) --------------------------
# Get a key at https://console.anthropic.com/  (takes precedence in auto mode)
# ANTHROPIC_API_KEY=
# FRIDGE_CLAUDE_MODEL=claude-opus-4-8

# --- Persistence ----------------------------------------------------------
# FRIDGE_DATABASE_URL=sqlite:///./fridge.db

# --- Freshness tuning -----------------------------------------------------
# Fraction of remaining shelf life at which an item is flagged "expiring".
# FRIDGE_EXPIRING_THRESHOLD=0.25
